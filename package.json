{
  "name": "mmo",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:server": "npm run dev -w @mmo/server",
    "dev:client": "npm run dev -w @mmo/client",
    "dev:editor": "npm run dev -w @mmo/editor",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test -w @mmo/shared",
    "gen:models": "node scripts/generate-models.mjs"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
